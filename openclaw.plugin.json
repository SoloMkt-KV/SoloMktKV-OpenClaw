{
  "id": "generator-kv",
  "name": "Generator-KV",
  "description": "Generate campaign KV images with SoloMkt-KV public models.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "Optional SoloMkt-KV API key. Prefer the credentials file for local use."
      },
      "credentialsPath": {
        "type": "string",
        "description": "Optional absolute path to .credentials.json."
      },
      "baseUrl": {
        "type": "string",
        "description": "SoloMkt-KV API base URL.",
        "default": "https://solosmart-uat.issmart.com.cn/solomkt_kv"
      },
      "generationTimeoutMs": {
        "type": "number",
        "description": "Generation request timeout in milliseconds.",
        "default": 600000
      }
    }
  },
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "generator_kv_configure_api_key",
      "generator_kv_list_models",
      "generator_kv_generate"
    ]
  },
  "toolMetadata": {
    "generator_kv_configure_api_key": {
      "optional": true
    },
    "generator_kv_list_models": {
      "optional": false
    },
    "generator_kv_generate": {
      "optional": false
    }
  }
}
